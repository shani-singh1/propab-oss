# Local run outputs (campaign JSON, benches, poll logs).
# NOTE: "artifacts/*" (not "artifacts/") so the "!" negations below can
# actually re-include nested paths — git never descends into a directory
# matched by a trailing-slash pattern, which silently no-ops any negation
# of a file inside it.
artifacts/*
# Functional data that MUST stay tracked: read/consumed by packages, services,
# tests, CI, or the bench regression harness. Everything else under artifacts/
# is local-only run output (campaign dumps, live-validation transcripts, eval
# result dumps, analysis notes) and is never pushed.
!artifacts/.gitkeep
!artifacts/routing_corpus_status.json

# Bench-harness baselines (regression-catchable engineering metrics)
!artifacts/bench/
!artifacts/bench/*.json

# Domain gap maps (routing/coverage reference data)
!artifacts/domain_gap_maps/
!artifacts/domain_gap_maps/*.json

# AstaBench eval logs and cached solutions
logs/

# Upstream clone — clone separately and apply scripts/patch_astabench_windows.py
asta-bench/

# Ad-hoc session scratch scripts (node/question-specific investigation one-offs)
scripts/_*.py
scripts/export_node_*.py
scripts/reconstruct_*.py
scripts/watch_*.py

# TypeScript incremental build cache (frontend)
*.tsbuildinfo

# Mandrake demo dataset wiring (requires private mandrake-data/)
demo/mandrake/

#agents file for cursor sessions
agent1.md
agent2.md
agent3.md

#propab design ref v1
propab-design-ref-v1.html

# Design/reference docs for the new researcher-SaaS product (not part of propab-oss)
ref/
