# ===========================================================================
# Propab — environment configuration (copy to .env)
# ===========================================================================
#   cp .env.example .env      # then set ONE LLM API key below
#
# For `docker compose up`, the ONLY thing you must fill in is your LLM
# provider + API key (Section 1). Docker Compose wires every infrastructure
# URL (Postgres / Redis / Qdrant / MinIO) to the internal service names
# automatically, so you can leave Sections 5+ untouched.
#
# How config is read:
#   - Under Docker, each service gets its env from docker-compose.yml. The
#     values in THIS file are substituted into ${...} placeholders there
#     (mainly the keys/flags in Sections 1-4). Vars NOT referenced as ${...}
#     in the dev compose file (the localhost infra URLs) are ignored under
#     Docker and only matter for a bare-metal local run (Section 8).
#   - The app itself reads config via pydantic BaseSettings (see
#     packages/propab-core/propab/config.py and services/literature/app/config.py).
#   - Real .env is git-ignored. Keep secrets out of version control.
# ===========================================================================


# ---------------------------------------------------------------------------
# 1. LLM PROVIDER + API KEY   ***REQUIRED — set one provider and its key***
# ---------------------------------------------------------------------------
# LLM_PROVIDER selects which key is used: openai | gemini | ollama
#   openai  -> needs OPENAI_API_KEY   (default; LLM_MODEL=gpt-4o)
#   gemini  -> needs GOOGLE_API_KEY   (also set EMBED_PROVIDER=google, see below)
#   ollama  -> no key; needs OLLAMA_BASE_URL reachable, LLM_MODEL=<local model>
LLM_PROVIDER=openai                         # required. openai | gemini | ollama
LLM_MODEL=gpt-4o                            # required. e.g. gpt-4o | gemini-2.0-flash | llama3.2

OPENAI_API_KEY=                            # REQUIRED when LLM_PROVIDER/EMBED_PROVIDER=openai
GOOGLE_API_KEY=                            # REQUIRED when provider=gemini/google (alias: GEMINI_API_KEY)
OLLAMA_BASE_URL=http://127.0.0.1:11434     # optional. only used when LLM_PROVIDER=ollama

# Optional per-role model split (orchestrator = "brain", worker = "experimenter").
# Both fall back to LLM_MODEL when unset — leave blank unless you know you want this.
# ORCHESTRATOR_MODEL=                       # optional. defaults to LLM_MODEL
# WORKER_MODEL=                             # optional. defaults to LLM_MODEL


# ---------------------------------------------------------------------------
# 2. EMBEDDINGS   (used for literature retrieval / semantic dedup)
# ---------------------------------------------------------------------------
# Match the provider to a key you set above, or embeddings silently fall back
# to non-embedding ranking (lower quality). If LLM_PROVIDER=gemini, set these
# to google so the same GOOGLE_API_KEY is reused.
EMBED_PROVIDER=openai                       # optional. openai | google (default openai)
EMBED_MODEL=text-embedding-3-small          # optional. OpenAI id; google default is gemini-embedding-2


# ---------------------------------------------------------------------------
# 3. CAMPAIGN PROFILE + ORCHESTRATION FEATURE FLAGS
# ---------------------------------------------------------------------------
# PROPAB_PROFILE tunes budgets/timeouts. docker-compose defaults this to
# "campaign" (full budgets). Use "dev" for fast, small, cheap local runs.
PROPAB_PROFILE=campaign                     # optional. campaign | dev (compose default: campaign)

# Orchestrator LLM reasoning loop (C3b). false = mechanical expansion (default,
# stable). true = an LLM decides each node's next strategic action (costs more).
ORCHESTRATOR_REASONING_ENABLED=false        # optional. default false

# Worker general-agent mode (S0). false = plugin/cluster path (default). true =
# every hypothesis runs the general think-act agent with the full tool catalog.
WORKER_GENERAL_AGENT_MODE=false             # optional. default false

# Shared bearer secret for internal API -> orchestrator calls. Blank = no auth
# (fine locally). Set a strong value for any shared/production deployment.
ORCHESTRATOR_INTERNAL_TOKEN=                # optional locally; recommended in prod

# Where the API delegates the campaign loop. Under Docker this is set by compose
# to http://orchestrator:8010. For a bare-metal run, blank = run the loop
# in-process; set to http://localhost:8010 to use a separate orchestrator.
ORCHESTRATOR_URL=                           # optional. blank = in-process (bare metal)


# ---------------------------------------------------------------------------
# 4. LITERATURE SERVICE (services/literature, port 8020)   — all optional
# ---------------------------------------------------------------------------
# The service runs out of the box with in-memory backends and an offline
# embedding fallback, so no keys are strictly required. Adding keys improves
# real-paper retrieval quality and removes public-API rate limits.
# NOTE: the literature service defaults LITERATURE_LLM_PROVIDER=gemini, so its
# (eval-only) LLM step wants GOOGLE_API_KEY. The core /prior pipeline has no LLM
# step, so the service is fully functional without it.
LITERATURE_LLM_PROVIDER=gemini              # optional. gemini | openai | ollama (compose default: gemini)
SEMANTIC_SCHOLAR_API_KEY=                   # optional. removes Semantic Scholar 429 rate-limiting
NCBI_API_KEY=                               # optional. raises PubMed/NCBI rate limits
# LITERATURE_POSTGRES_BACKEND=memory        # optional. memory | postgres (default memory)
# LITERATURE_QDRANT_BACKEND=memory          # optional. memory | qdrant (default memory)
# LITERATURE_LLM_MODEL=gemini-3-flash-preview   # optional. cheap sub-task model
# LITERATURE_ANSWER_MODEL=gemini-3.1-pro-preview # optional. frontier model, LitQA2 eval only


# ---------------------------------------------------------------------------
# 5. STORAGE / DATA (Docker sets these automatically — override only in prod)
# ---------------------------------------------------------------------------
# LIFETIME_STORE_BACKEND: json (tests/local) | postgres (cross-campaign upserts).
# Compose sets this to postgres for the app services.
LIFETIME_STORE_BACKEND=json                 # optional. json | postgres (compose default: postgres)
PROPAB_DATA_DIR=./data                      # optional. lifetime store, caches, snapshots
QDRANT_COLLECTION=propab_chunks             # optional. Qdrant collection name
MINIO_BUCKET=propab                         # optional. object-storage bucket name
MINIO_SECURE=false                          # optional. true if MinIO/S3 is behind TLS


# ---------------------------------------------------------------------------
# 6. SANDBOX (worker runs generated code in a disposable Docker container)
# ---------------------------------------------------------------------------
# SANDBOX_IMAGE must be an existing local image with numpy/scipy/torch — it
# defaults to the worker image. Compose builds the worker as
# <compose-project>-worker; the default below assumes the repo dir is
# "propab-oss". If you clone into a differently named directory, either keep the
# dir name propab-oss, set COMPOSE_PROJECT_NAME=propab-oss, or set SANDBOX_IMAGE
# to the actual built image name (see docs/beta-setup.md).
SANDBOX_IMAGE=propab-oss-worker:latest      # optional. must be a real local image
SANDBOX_TIMEOUT_SEC=120                     # optional. max CPU seconds per sandboxed block
SANDBOX_CODE_MAX_RETRIES=3                  # optional. Docker executions per code step (min 1)
# Optional per-cluster overrides (clamped 5-7200s):
# SANDBOX_TIMEOUT_DEEP_LEARNING=600
# SANDBOX_TIMEOUT_ALGORITHM_OPTIMIZATION=
# SANDBOX_TIMEOUT_ML_RESEARCH=


# ---------------------------------------------------------------------------
# 7. SUB-AGENT / PAPER / RERANKER TUNING   — all optional, defaults are fine
# ---------------------------------------------------------------------------
SUB_AGENT_PLAN_SOURCE=llm                    # optional. heuristic | llm | hybrid (dev profile forces heuristic)
SUB_AGENT_MAX_PLANNED_STEPS=6                # optional
SUB_AGENT_MAX_ROUNDS=4                       # optional
SUB_AGENT_TOOLS_PER_ROUND=4                  # optional
PAPER_POLICY=substantive                     # optional. substantive | strict_confirmed | always
PAPER_MIN_SUBSTANTIVE_TOOLS=2                # optional
RERANKER_ENABLED=false                       # optional. needs pip install -e ".[rerank]"
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2   # optional
# Optional Celery task limits (worker): CELERY_TASK_SOFT_TIME_LIMIT_SEC / CELERY_TASK_TIME_LIMIT_SEC
# Optional domain data keys: MP_API_KEY / MATERIALS_PROJECT_API_KEY (materials), MNIST_DATA_DIR (ML tools)
#
# This file covers the vars that matter for setup + day-to-day operation. The
# app exposes many more fine-grained tuning knobs (campaign_*, research_*,
# literature_* retrieval thresholds, agent budgets). The full, authoritative
# list with defaults is the Settings class in
# packages/propab-core/propab/config.py (and services/literature/app/config.py
# for LITERATURE_* vars). Any field there is settable via its UPPER_SNAKE name.


# ---------------------------------------------------------------------------
# 8. INFRASTRUCTURE URLs   ***BARE-METAL / PROD ONLY — ignored under dev Docker***
# ---------------------------------------------------------------------------
# The dev docker-compose.yml hard-codes these to the internal service names, so
# you do NOT set them for `docker compose up`. They are needed only if you run
# the services directly on your host (pip install) or use docker-compose.prod.yml.
DATABASE_URL=postgresql+asyncpg://propab:propab@localhost:5432/propab
DATABASE_URL_SYNC=postgresql+psycopg://propab:propab@localhost:5432/propab   # Alembic (sync driver)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=propab
MINIO_SECRET_KEY=propab_secret
# Prod compose only: POSTGRES_PASSWORD, PROPAB_API_IMAGE / PROPAB_ORCHESTRATOR_IMAGE / PROPAB_WORKER_IMAGE
