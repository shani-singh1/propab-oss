DATABASE_URL=postgresql+asyncpg://propab:propab@localhost:5432/propab
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
OPENAI_API_KEY=
# Google Gemini (Generative Language API) when LLM_PROVIDER=gemini — also accepts GEMINI_API_KEY
GOOGLE_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
# LLM_PROVIDER=gemini and LLM_MODEL=gemini-2.0-flash (or gemini-1.5-flash, etc.)
# Local chat models: LLM_PROVIDER=ollama, LLM_MODEL=llama3.2, OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Run research_loop in a separate process (docker compose sets this for api → orchestrator).
ORCHESTRATOR_URL=
ORCHESTRATOR_INTERNAL_TOKEN=
# Sub-agent tool plan: heuristic | llm | hybrid (requires OpenAI key or Ollama).
SUB_AGENT_PLAN_SOURCE=heuristic
SUB_AGENT_MAX_PLANNED_STEPS=4
EMBED_PROVIDER=openai
EMBED_MODEL=text-embedding-3-small
QDRANT_URL=
QDRANT_COLLECTION=propab_chunks
PROPAB_DATA_DIR=./data
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=propab
MINIO_SECURE=false
LITERATURE_ANSWER_SIMILARITY=0.92
SANDBOX_CODE_MAX_RETRIES=3
# Sandbox CPU timeout (seconds). Global default; per-domain table in ARCHITECTURE.md §13.2.
SANDBOX_TIMEOUT_SEC=60
# Optional overrides, e.g. SANDBOX_TIMEOUT_DEEP_LEARNING=600 (clamped 5–7200).
# SANDBOX_TIMEOUT_DEEP_LEARNING=
# SANDBOX_TIMEOUT_ALGORITHM_OPTIMIZATION=
# SANDBOX_TIMEOUT_ML_RESEARCH=
# Alembic uses a sync driver; replace asyncpg with psycopg for CLI migrations.
DATABASE_URL_SYNC=postgresql+psycopg://propab:propab@localhost:5432/propab
# Phase 2 optional local cross-encoder (requires: pip install -e ".[rerank]")
RERANKER_ENABLED=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
